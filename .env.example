NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Apenas para os scripts em ./scripts/ (apply-migrations.js, seed-users.js)
SUPABASE_DB_PASSWORD=your-postgres-password-here
SEED_USER_PASSWORD=TrocarSenha123!

# URL pública do sistema (usada nos webhooks de integração)
NEXT_PUBLIC_SITE_URL=https://app.seudominio.com.br

# ===== Storage de mídia em Cloudflare R2 (S3-compatível) =====
# Ligue o driver R2 (público — o cliente passa a subir direto pro R2):
NEXT_PUBLIC_STORAGE_DRIVER=r2
# Credenciais do R2 (secretas — só servidor):
R2_ACCOUNT_ID=seu-account-id-cloudflare
R2_ACCESS_KEY_ID=sua-access-key
R2_SECRET_ACCESS_KEY=sua-secret-key
R2_BUCKET=arini-midia
# Domínio público do bucket (R2 public dev URL ou domínio próprio):
R2_PUBLIC_URL=https://cdn.seudominio.com.br
